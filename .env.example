# Wellspring environment variables
# Client-side (safe to ship): anon key only. NEVER put the service-role key here.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only (Edge Functions / admin jobs). Set via `supabase secrets set`.
# SUPABASE_SERVICE_ROLE_KEY=...   # service-role: server-only admin jobs ONLY
# ANTHROPIC_API_KEY=...           # zero-retention terms required
# GEMINI_API_KEY=...
# STRIPE_SECRET_KEY=...
# STRIPE_WEBHOOK_SECRET=...
